.page {
  min-height: 100vh;
  padding: 28rpx;
  background: linear-gradient(180deg, rgba(15, 118, 110, 0.1), rgba(247, 248, 244, 0) 360rpx), #f7f8f4;
}

.hero {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 18rpx 0 24rpx;
}

.eyebrow,
.label {
  color: #0f766e;
  font-size: 24rpx;
  font-weight: 800;
  text-transform: uppercase;
}

.title {
  color: #13201f;
  font-size: 54rpx;
  font-weight: 900;
  line-height: 1.08;
}

.panel {
  margin-bottom: 22rpx;
  padding: 24rpx;
  border: 1rpx solid #d8ded9;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 18rpx 48rpx rgba(19, 32, 31, 0.08);
}

.section-head,
.card-title,
.button-row,
.compose {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.heading {
  display: block;
  color: #13201f;
  font-size: 34rpx;
  font-weight: 900;
}

.source {
  width: 100%;
  min-height: 210rpx;
  margin-top: 20rpx;
  padding: 20rpx;
  border: 1rpx solid #d8ded9;
  border-radius: 16rpx;
  background: #fbfcfb;
  box-sizing: border-box;
  line-height: 1.55;
}

.picker-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 14rpx;
  margin: 18rpx 0;
}

.picker-box {
  display: flex;
  justify-content: space-between;
  padding: 18rpx 20rpx;
  border: 1rpx solid #d8ded9;
  border-radius: 16rpx;
  background: #fbfcfb;
  color: #63706f;
  font-size: 26rpx;
  font-weight: 700;
}

.button-row {
  flex-wrap: wrap;
  justify-content: flex-start;
}

.primary,
.secondary,
.ghost {
  min-height: 78rpx;
  margin: 0;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 800;
}

.primary {
  background: #0f766e;
  color: #ffffff;
}

.secondary,
.ghost {
  border: 1rpx solid #d8ded9;
  background: #ffffff;
  color: #13201f;
}

.pill {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #e8f5f3;
  color: #115e59;
  font-size: 22rpx;
  font-weight: 900;
}

.spoken {
  display: block;
  margin-top: 20rpx;
  color: #13201f;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.45;
}

.tip {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: 16rpx;
  padding: 18rpx;
  border-left: 8rpx solid #0f766e;
  border-radius: 14rpx;
  background: #fbfcfb;
}

.tip.reduction {
  border-left-color: #c0564a;
}

.tip.assimilation {
  border-left-color: #2f5f98;
}

.tip.voicing {
  border-left-color: #b98222;
}

.tip-title {
  color: #13201f;
  font-size: 28rpx;
  font-weight: 900;
}

.tip-body,
.muted,
.analysis {
  color: #63706f;
  font-size: 27rpx;
  line-height: 1.6;
}

.analysis {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 14rpx;
  background: #f2f5f3;
}

.tabs {
  width: 100%;
  margin: 18rpx 0;
  white-space: nowrap;
}

.tab {
  display: inline-flex;
  min-height: 66rpx;
  margin-right: 12rpx;
  padding: 0 22rpx;
  border: 1rpx solid #d8ded9;
  background: #ffffff;
  color: #63706f;
  font-size: 25rpx;
}

.tab.active {
  background: #0f766e;
  color: #ffffff;
}

.chat-log {
  height: 430rpx;
  padding: 18rpx;
  border: 1rpx solid #d8ded9;
  border-radius: 16rpx;
  background: #f8faf8;
  box-sizing: border-box;
}

.message {
  max-width: 86%;
  margin-bottom: 14rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  line-height: 1.5;
  font-size: 27rpx;
}

.message.user {
  margin-left: auto;
  background: #0f766e;
  color: #ffffff;
}

.message.coach {
  border: 1rpx solid #d8ded9;
  background: #ffffff;
  color: #13201f;
}

.compose {
  margin-top: 16rpx;
}

.compose input {
  flex: 1;
  min-height: 78rpx;
  padding: 0 18rpx;
  border: 1rpx solid #d8ded9;
  border-radius: 16rpx;
  background: #ffffff;
}

.send {
  min-width: 132rpx;
}
